__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/
.ipynb_checkpoints/

# Node / JS
node_modules/
dist/
build/
.netlify/
*.log
npm-debug.log*

# Data artifacts (raw downloads, model binaries) — keep these out of git
data/raw/
data/interim/
*.csv
!data/sample/*.csv
!examples/*.csv
*.parquet
*.pkl
*.joblib
*.h5
*.onnx
# ...except the deployed model bundle, shipped so the company can run inference
# without the (proprietary, un-committed) training dataset.
!model/bundle.pkl

# OS / editor
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Claude Flow runtime state (local-only coordination data)
.claude-flow/
.claude/scheduled_tasks.lock

# Conversation logs (auto-generated by ai-logging hook; local-only)
claude-*-conversation.md
*.md.bak

# Deliverable: submitted predictions
!predictions/predictions.csv

# Rails app (api/) — runtime, caches, and SECRETS
api/tmp/
api/log/
api/storage/
api/.bundle/
api/config/master.key
api/config/credentials.yml.enc
api/public/assets/

# CatBoost training artifacts / experiment results
catboost_info/
experiments/results.csv

# Handoff docs (context-management, local-only)
handoff/

# Design export drops (raw Claude Design zips)
*.zip

# Booking feature runtime state (local-only)
data/conversions.jsonl
data/booking_config.json
