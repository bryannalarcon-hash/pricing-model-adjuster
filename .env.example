# Copy to .env and fill in real values. Never commit .env.

# --- HouseAccount staging booking API (POST /api/bookings) : HMAC request signing ---
# Partner identity sent as the App-Name header; the signing key computes
# App-Signature = HMAC-SHA256(App-Timestamp + "." + payload). HouseAccount-issued.
HOUSEACCOUNT_APP_NAME=gauntlet
HOUSEACCOUNT_SIGNING_KEY=

# --- My pricing endpoint (Appendix A) : Authorization: Bearer <secret> ---
# Shared secret I define; validated with constant-time comparison on /pricing-estimate.
GAUNTLET_PRICING_SECRET=

# --- GPU compute ---
# Vast.ai API key for optional GPU training/hosting of open-source models.
VAST_API_KEY=
